# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database — debe coincidir con POSTGRES_* del docker-compose raíz
DATABASE_URL=postgresql://admin_portal:your_password@localhost:5432/admin_portal_db

# Auth — cambiar en producción
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Usuario admin inicial (usado por prisma/seed.ts)
ADMIN_EMAIL=admin@adminportal.com
ADMIN_PASSWORD=change_this_password
