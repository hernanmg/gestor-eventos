# ─── Variables de entorno para producción ────────────────────────────────────
# Copiar este archivo a backend/.env y completar todos los valores
#   cp deploy/.env.production.example backend/.env
# ──────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Base de datos ─────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql://eventos_user:TU_PASSWORD_DB@localhost:5432/eventos_db

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios.
# Generar con: openssl rand -base64 32
JWT_SECRET=TU_JWT_SECRET_MINIMO_32_CARACTERES

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL pública del frontend (sin barra final)
FRONTEND_URL=https://TU_DOMINIO

# ── Usuario administrador inicial ─────────────────────────────────────────────
# Usado por prisma/seed.ts en el primer deploy.
# Cambiar la contraseña inmediatamente después del primer login.
ADMIN_EMAIL=admin@TU_DOMINIO
ADMIN_PASSWORD=TU_ADMIN_PASSWORD_INICIAL

# ── Puppeteer / Chromium ──────────────────────────────────────────────────────
# Ruta al ejecutable de Chromium instalado por setup.sh.
# En Ubuntu 22.04 con chromium-browser: /usr/bin/chromium-browser
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
